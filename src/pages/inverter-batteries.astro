---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQSection from '../components/FAQSection.astro';
import site from '../data/site.json';

const faqs = [
  { q: 'Which inverter battery is best for villages in Gajwel area?', a: 'For villages with 6–10 hour power cuts, the Exide InvaTubular 150AH or 200AH is the best choice. These tubular batteries handle deep discharge well. Price from ₹9,500–₹14,500 at Royal Batteries Gajwel.' },
  { q: 'What AH inverter battery do I need?', a: 'For 3 fans + 3 lights for 4 hours: 120–150AH. For 4 fans + 4 lights + TV for 6 hours: 150–200AH. Visit our showroom or call 9397617823 — we\'ll calculate the exact requirement for your home load.' },
  { q: 'Do you install inverter batteries at home?', a: 'Yes! We deliver and install inverter batteries at homes, shops, and farms across a 50 km radius from Gajwel. Installation includes connecting to your existing inverter and checking that everything works correctly.' },
  { q: 'How long do inverter batteries last in Telangana?', a: 'Good-quality tubular batteries (Exide InvaTubular, Amaron Tall Tubular) last 4–6 years with proper water maintenance every 2–3 months. Flat-plate batteries last 2–3 years.' },
  { q: 'What is the price of an inverter battery in Gajwel?', a: 'Inverter battery prices at Royal Batteries: Flat plate (100AH) from ₹4,500; Tubular (150AH) from ₹9,000; Tubular (200AH) from ₹12,500. Price includes installation and old battery disposal.' },
];
---
<BaseLayout
  title="Inverter Battery in Gajwel | Exide & Amaron Tubular Batteries"
  description="Best inverter batteries in Gajwel for home and village backup. Exide InvaTubular 150AH & 200AH. Free home delivery & installation across Siddipet, Medak. Call 9397617823."
  canonical="/inverter-batteries"
  breadcrumbs={[{ name: 'Inverter Batteries', url: '/inverter-batteries' }]}
>
  <div class="hero-inner-page">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a><span class="sep">›</span><span aria-current="page">Inverter Batteries</span>
      </nav>
      <h1 class="page-h1">Inverter Battery in Gajwel | Tubular Batteries for Power Cuts</h1>
      <p class="page-sub">Exide InvaTubular &amp; Amaron Tall Tubular batteries — delivered and installed at your home across Siddipet, Medak &amp; 50 km radius.</p>
      <div style="display:flex; gap:12px; margin-top:24px; flex-wrap:wrap;">
        <a href={`tel:${site.phone}`} class="btn btn-primary">📞 Call {site.phoneDisplay}</a>
        <a href={site.whatsapp} target="_blank" rel="noopener" class="btn btn-whatsapp">💬 WhatsApp Order</a>
      </div>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="content-section" style="max-width:840px;">
        <h2>Why Telangana Villages Need a Good Inverter Battery</h2>
        <p>Power cuts in Gajwel mandal, Siddipet district, and Medak district can range from 4 hours to 10+ hours daily — especially during summer months and agricultural pumping seasons. A quality inverter battery is not a luxury; it's essential for a functioning household or business.</p>
        <p>Royal Batteries stocks the best inverter batteries in Telangana — tubular batteries specifically designed for deep discharge cycles that happen in rural areas with extended power cuts.</p>

        <h2>Our Inverter Battery Range</h2>
        <div style="display:grid; gap:16px; margin:20px 0;">
          {[
            { name: 'Exide InvaTubular 150 AH', best: 'Best Seller', price: '₹9,500–₹11,000', backup: '~5 hrs (3 fans, 3 lights)', warranty: '36 months', desc: 'India\'s #1 tubular battery. Perfect for homes with moderate load and 4–6 hour power cuts. C20 rating for village use.' },
            { name: 'Exide InvaTubular 200 AH', best: 'Best for Villages', price: '₹12,500–₹15,000', backup: '~8 hrs (4 fans, 4 lights, TV)', warranty: '36 months', desc: 'High-capacity tubular battery for extended village power cuts. Handles daily deep discharge with ease.' },
            { name: 'Amaron Current Tall Tubular 150 AH', best: 'Fast Charge', price: '₹10,500–₹12,500', backup: '~5 hrs (3 fans, 3 lights)', warranty: '36 months', desc: 'Superior charge acceptance — reaches 80% charge quickly, ideal when power comes for short windows.' },
            { name: 'Exide Flat FXST 100 AH', best: 'Budget', price: '₹4,500–₹5,500', backup: '~2 hrs (2 fans, 2 lights)', warranty: '24 months', desc: 'Affordable flat plate battery for families with smaller loads and 1–3 hour power cuts.' },
          ].map(b => (
            <div class="card" style="padding:24px;">
              <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:10px;">
                <h3 style="font-size:1rem;">{b.name}</h3>
                <span style="font-size:0.75rem; background:var(--red); color:#fff; padding:3px 10px; border-radius:50px; font-weight:600; white-space:nowrap; flex-shrink:0;">{b.best}</span>
              </div>
              <p style="font-size:0.88rem; margin-bottom:12px;">{b.desc}</p>
              <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:8px; font-size:0.82rem; color:var(--muted);">
                <span>💰 {b.price}</span>
                <span>⏱ {b.backup}</span>
                <span>🛡 {b.warranty}</span>
              </div>
            </div>
          ))}
        </div>

        <h2>Free AH Calculation — Tell Us Your Load</h2>
        <p>Not sure which AH battery you need? Call or WhatsApp us at {site.phoneDisplay} with your list of appliances. We'll calculate the exact battery size for your home within minutes — completely free.</p>

        <p>As a general guide:</p>
        <ul>
          <li>2 fans + 2 lights: 100 AH (2–3 hours backup)</li>
          <li>3 fans + 3 lights: 150 AH (4–5 hours backup)</li>
          <li>4 fans + 4 lights + TV: 200 AH (6–8 hours backup)</li>
          <li>Add <strong>50 AH</strong> per additional air cooler</li>
        </ul>
      </div>
    </div>
  </section>

  <FAQSection faqs={faqs} title="Inverter Battery FAQs — Gajwel &amp; Telangana Villages" />

  <section class="section-sm">
    <div class="container">
      <div class="cta-banner">
        <div><h2>Order Your Inverter Battery Today</h2><p>Delivered and installed at your home — Gajwel, Siddipet, Medak &amp; villages within 50 km. Call before 4 PM for same-day delivery.</p></div>
        <div class="cta-actions">
          <a href={`tel:${site.phone}`} class="btn btn-outline-white btn-lg">📞 {site.phoneDisplay}</a>
          <a href={site.whatsapp} target="_blank" rel="noopener" class="btn btn-whatsapp btn-lg">💬 WhatsApp</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
