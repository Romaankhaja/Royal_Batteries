---
import BaseLayout from '../../layouts/BaseLayout.astro';
import site from '../../data/site.json';
import blogData from '../../data/blog.json';

export async function getStaticPaths() {
  return blogData.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.title,
  description: post.description,
  datePublished: post.date,
  dateModified: post.date,
  author: {
    '@type': 'Person',
    name: site.owner,
    affiliation: { '@type': 'Organization', name: site.siteName },
  },
  publisher: {
    '@type': 'Organization',
    name: site.siteName,
    logo: { '@type': 'ImageObject', url: `${site.url}/assets/logo.png` },
  },
  keywords: post.keywords.join(', '),
  mainEntityOfPage: { '@type': 'WebPage', '@id': `${site.url}/blog/${post.slug}` },
};

const relatedPosts = blogData.filter(p => p.slug !== post.slug).slice(0, 3);
---
<BaseLayout
  title={post.title}
  description={post.description}
  canonical={`/blog/${post.slug}`}
  schema={articleSchema}
  breadcrumbs={[
    { name: 'Blog', url: '/blog' },
    { name: post.metaTitle.replace(' | Royal Batteries', ''), url: `/blog/${post.slug}` },
  ]}
>
  <div class="hero-inner-page">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a><span class="sep">›</span>
        <a href="/blog">Blog</a><span class="sep">›</span>
        <span aria-current="page">{post.category}</span>
      </nav>
      <div class="blog-cat" style="margin-bottom:12px;">{post.category}</div>
      <h1 class="page-h1" style="max-width:760px;">{post.title.replace(' | Royal Batteries', '')}</h1>
      <div style="display:flex; gap:16px; align-items:center; flex-wrap:wrap; margin-top:16px; font-size:0.85rem; color:var(--muted);">
        <span>By <strong>{site.owner}</strong></span>
        <span>·</span>
        <time datetime={post.date}>{new Date(post.date).toLocaleDateString('en-IN', { day:'numeric', month:'long', year:'numeric' })}</time>
        <span>·</span>
        <span>{post.readTime}</span>
      </div>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div style="display:grid; grid-template-columns: 1fr 300px; gap:48px; align-items:start;">

        <!-- Article Content -->
        <article class="blog-content" itemscope itemtype="https://schema.org/Article">
          <meta itemprop="headline" content={post.title} />
          <meta itemprop="datePublished" content={post.date} />
          <div itemprop="articleBody" set:html={post.content} />

          <!-- CTA inside article -->
          <div class="card" style="padding:28px; margin-top:40px; background:var(--light); border-color:transparent;">
            <h3 style="margin-bottom:8px;">Need a Battery in Gajwel or Nearby?</h3>
            <p style="color:var(--muted); font-size:0.9rem; margin-bottom:20px;">
              Royal Batteries is Gajwel's Exide CARE authorized dealer. Free diagnostics, genuine batteries, same-day delivery to 50 km radius.
            </p>
            <div style="display:flex; gap:12px; flex-wrap:wrap;">
              <a href={`tel:${site.phone}`} class="btn btn-primary">📞 {site.phoneDisplay}</a>
              <a href={site.whatsapp} target="_blank" rel="noopener" class="btn btn-whatsapp">💬 WhatsApp</a>
            </div>
          </div>
        </article>

        <!-- Sidebar -->
        <aside style="position:sticky; top:80px; display:flex; flex-direction:column; gap:20px;">
          <div class="card" style="padding:24px;">
            <h3 style="font-size:0.95rem; margin-bottom:16px;">Quick Contact</h3>
            <div style="display:flex; flex-direction:column; gap:10px;">
              <a href={`tel:${site.phone}`} class="btn btn-primary btn-sm" style="justify-content:center;">📞 Call {site.phoneDisplay}</a>
              <a href={site.whatsapp} target="_blank" rel="noopener" class="btn btn-whatsapp btn-sm" style="justify-content:center;">💬 WhatsApp</a>
            </div>
            <div style="margin-top:16px; font-size:0.8rem; color:var(--muted); display:flex; flex-direction:column; gap:6px;">
              <span>📍 Opp. Munsif Court, Gajwel</span>
              <span>🕐 {site.hours}</span>
            </div>
          </div>

          <div class="card" style="padding:20px;">
            <h3 style="font-size:0.88rem; margin-bottom:14px; color:var(--muted); font-weight:600; text-transform:uppercase; letter-spacing:0.05em;">Our Services</h3>
            <div style="display:flex; flex-direction:column; gap:8px;">
              <a href="/car-batteries" style="font-size:0.88rem; color:var(--text);">🚗 Car Batteries</a>
              <a href="/bike-batteries" style="font-size:0.88rem; color:var(--text);">🏍️ Bike Batteries</a>
              <a href="/inverter-batteries" style="font-size:0.88rem; color:var(--text);">⚡ Inverter Batteries</a>
              <a href="/battery-delivery-service" style="font-size:0.88rem; color:var(--text);">🚚 Delivery Service</a>
            </div>
          </div>

          {relatedPosts.length > 0 && (
            <div class="card" style="padding:20px;">
              <h3 style="font-size:0.88rem; margin-bottom:14px; color:var(--muted); font-weight:600; text-transform:uppercase; letter-spacing:0.05em;">Related Articles</h3>
              <div style="display:flex; flex-direction:column; gap:12px;">
                {relatedPosts.map(rp => (
                  <a href={`/blog/${rp.slug}`} style="font-size:0.85rem; color:var(--text); line-height:1.4;">
                    {rp.title.replace(' | Royal Batteries', '')}
                  </a>
                ))}
              </div>
            </div>
          )}
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
